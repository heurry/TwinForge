{
  "project_name": "llm_train_platform_miniv2",
  "version": "v1.0",
  "model_family": "Qwen2.5",
  "base_model": "Qwen/Qwen2.5-3B",
  "tokenizer": "Qwen/Qwen2.5-3B",
  "datasets": {
    "cpt": [
      {
        "name": "fineweb_sample",
        "source": "HuggingFaceFW/fineweb",
        "subset": "sample-10BT",
        "language": "en",
        "streaming": true,
        "target_raw_size_gb": 1.5,
        "max_samples": 300000,
        "text_field": "text",
        "split": "train"
      },
      {
        "name": "mnbvc_gov_subset",
        "source": "MNBVC",
        "subset": "gov",
        "language": "zh",
        "streaming": false,
        "target_raw_size_gb": 1.0,
        "max_samples": 200000,
        "text_field": "text",
        "split": "train"
      },
      {
        "name": "stackv2_python_mini",
        "source": "bigcode/the-stack-v2",
        "subset": "python",
        "language": "code",
        "streaming": true,
        "target_raw_size_gb": 0.3,
        "max_samples": 50000,
        "text_field": "content",
        "split": "train"
      }
    ],
    "sft": [
      {
        "name": "ultrachat_200k_mini",
        "source": "HuggingFaceH4/ultrachat_200k",
        "subset": "default",
        "language": "multi",
        "target_samples": 20000,
        "message_field": "messages",
        "split": "train_sft"
      },
      {
        "name": "wildchat_mini",
        "source": "allenai/WildChat",
        "subset": "default",
        "language": "multi",
        "target_samples": 10000,
        "message_field": "conversation",
        "split": "train"
      }
    ],
    "eval": [
      {
        "name": "gsm8k",
        "source": "openai/gsm8k",
        "subset": "main",
        "split": "test"
      },
      {
        "name": "mmlu_mini",
        "source": "cais/mmlu",
        "subjects": [
          "college_computer_science",
          "machine_learning",
          "high_school_mathematics",
          "formal_logic",
          "electrical_engineering"
        ],
        "split": "test"
      },
      {
        "name": "humaneval",
        "source": "openai/openai_humaneval",
        "subset": "openai_humaneval",
        "split": "test"
      },
      {
        "name": "mbpp",
        "source": "Muennighoff/mbpp",
        "split": "test"
      }
    ]
  },
  "preprocess": {
    "min_text_chars": 50,
    "max_text_chars": 12000,
    "drop_empty": true,
    "normalize_whitespace": true,
    "dedup": {
      "enabled": true,
      "method": "minhash_or_exact_hash"
    }
  },
  "tokenization": {
    "cpt_seq_len": 2048,
    "sft_seq_len": 2048,
    "packing": true,
    "add_eos": true,
    "truncation": true
  }
}